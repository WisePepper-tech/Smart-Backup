# Storage Mode: 1 = Local Only, 2 = Cloud Sync (S3)
STORAGE_MODE=1

# S3 Configuration (required if STORAGE_MODE=2)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=smart-backups

# App Settings
LOG_LEVEL=INFO
DOCKER_MODE=true

# API settings
BACKUP_PATH=./backups
ALLOWED_SOURCE_PATH=/data
API_KEY=your_api_key  # Use for generate key command: python -c "import secrets; print(secrets.token_hex(32))" and past value here